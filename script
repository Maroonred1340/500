import tkinter as tk

NUM_WINDOWS = 500

root = tk.Tk()
root.withdraw()

for i in range(NUM_WINDOWS):
  win = tk.Toplevel(root)
  win.title("ㅋ")
  x = 50 * (i % 20)
  y = 50 * (i // 20)
  win.geometry(f"200x100+{x}+{y}")
  label = tk.Label(win, text="수고ㅋ", font=("Arial", 18))
  label.pack(expand=True)

root.mainloop()
